# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://admin:password123@localhost:27017/jewellery_manufacturing?authSource=admin

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Amazon SP-API Configuration (Optional)
CSP_AMAZON_CLIENT_ID=your-amazon-client-id
CSP_AMAZON_CLIENT_SECRET=your-amazon-client-secret
CSP_AMAZON_REFRESH_TOKEN=your-amazon-refresh-token
CSP_AMAZON_MARKETPLACE_ID=your-marketplace-id
CSP_AMAZON_ACCESS_TOKEN=
CSP_AMAZON_TOKEN_REFRESHED_AT=

# eBay API Configuration (Optional)
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
EBAY_REFRESH_TOKEN=your-ebay-refresh-token

# WhatsApp Configuration (Optional)
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
